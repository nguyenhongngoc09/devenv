#!/bin/bash
echo "Correcting filesystem permissions..."

if [ -z "$1" ]; then
  TARGET="projects"
else
  TARGET="$1"
fi

bin/clinotty find "$TARGET" -type f -exec chmod u+w {} \;
bin/clinotty find "$TARGET" -type d -exec chmod u+w {} \;

if bin/clinotty test -f "$TARGET/bin/console"; then
  bin/clinotty chmod u+x "$TARGET/bin/console"
fi

echo "Filesystem permissions corrected."
