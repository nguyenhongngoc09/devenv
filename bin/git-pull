#!/bin/bash
[ -z "$1" ] && echo "Please specify the git repository URL" && exit
GIT_BRANCH=${2:-develop}
PROJECT_FOLDER=${3:-$(basename "${1%.git}")}
PROJECT_FOLDER=${PROJECT_FOLDER##*/}
PROJECT_FOLDER=${PROJECT_FOLDER:-project}

mkdir -p "projects/$PROJECT_FOLDER"
REAL_SRC=$(cd -P "projects/$PROJECT_FOLDER" && pwd)

cd "$REAL_SRC"
git init
git remote add origin $1
git checkout -b $GIT_BRANCH
git pull origin $GIT_BRANCH
